generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  businessName String
  slug         String   @unique
  templateId   String?
  template     Template? @relation(fields: [templateId], references: [id])
  plan         String   @default("basic")
  isActive     Boolean  @default(true)
  domain       String?
  r2BucketKey  String?
  lastPublishedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteConfig   SiteConfig[]
  blogPosts    BlogPost[]
  pages        Page[]
  mediaFiles   MediaFile[]
  sessions     Session[]
  siteStatistics SiteStatistics?
  sitePublishLogs SitePublishLog[]

  @@map("clients")
}

model Session {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  niche       String
  thumbnail   String?
  r2Key       String   @unique // Path to template in R2 bucket (e.g., "templates/lawyer-premium")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients     Client[]
  schema      TemplateSchema?

  @@map("templates")
}

model SiteConfig {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  key       String
  value     String   @db.Text
  type      String   @default("text")
  jsonValue Json?    // For complex structured data (sections, colors, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
  @@map("site_configs")
}

// Template Schema - defines editable structure for each template
model TemplateSchema {
  id           String   @id @default(cuid())
  templateId   String   @unique
  template     Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  schema       Json     // Stores sections, fields, editable elements structure
  pages        Json     // Array of available pages in template
  sections     Json     // Available section types with their configuration
  fields       Json     // Field types (text, image, color, etc.)
  autoDetected Boolean  @default(false) // Whether schema was auto-parsed from HTML
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("template_schemas")
}

// Site Statistics - Cloudflare analytics data
model SiteStatistics {
  id            String   @id @default(cuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Cloudflare data
  totalVisits   Int      @default(0)
  uniqueVisitors Int     @default(0)
  pageViews     Int      @default(0)
  
  // Breakdown data (stored as JSON)
  countries     Json?    // [{country, visits}, ...]
  referrers     Json?    // [{source, visits}, ...]
  pages         Json?    // [{page, views}, ...]
  devices       Json?    // [{device, percentage}, ...]
  
  // Time series data for charts
  dailyStats    Json?    // Last 30 days of data
  
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@map("site_statistics")
}

// Site Publish Log - track all publishes
model SitePublishLog {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  status      String   // success, error, pending
  version     Int      // Site version number
  url         String   // Published URL
  errorMessage String? // If failed
  
  // What was published
  changesSummary Json? // {sections: 5, images: 3, texts: 12, etc.}
  
  publishedAt DateTime @default(now())
  publishedBy String?  // User who published

  @@index([clientId, publishedAt])
  @@map("site_publish_logs")
}

model BlogPost {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  excerpt     String?   @db.Text
  content     String    @db.Text
  coverImage  String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, slug])
  @@map("blog_posts")
}

model Page {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  sections  Json     @default("[]")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, slug])
  @@map("pages")
}

model MediaFile {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  url       String
  r2Key     String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  alt       String?
  folder    String   @default("/") // For organizing in CMS (e.g., "/images/hero", "/blog")
  tags      Json?    // For categorization
  createdAt DateTime @default(now())

  @@map("media_files")
}
